#!/bin/bash

a=" Vimrc"
b="yYazi.toml"
c="wWaybar config"
d="mMako config"
e="Sway config"
f="sStuff2remember"
g="cConfiguration.nix"
h="fFlake.nix"
i="Pkgs"
j="uUpdate Nixos"
ai="\0icon\x1fvim"
bi="\0icon\x1fsystem-file-manager"
ci="\0icon\x1fwayland"
di="\0icon\x1fnotion"
ei="\0icon\x1fdesktop-effects"
fi="\0icon\x1fnotepad"
gi="\0icon\x1fpreferences-system-services"
hi="\0icon\x1fpreferences-system-services"
ii="\0icon\x1fpreferences-system-services"
ji="\0icon\x1fupsource"

selected=$(echo -e "$e$ei\n$a$ai\n$b$bi\n$c$ci\n$d$di\n$f$fi\n$g$gi\n$h$hi\n$i$ii\n$j$ji" | fuzzel --match-mode exact --lines 17 --auto-select -d )
case $selected in
    "$a")
        $TERMINAL -e vim ~/.config/vim/vimrc;;
    "$b")
        $TERMINAL -e vim ~/.config/yazi/keymap.toml;;
    "$c")
        $TERMINAL -e vim ~/.config/waybar/config-sway.jsonc;;
    "$d")
        $TERMINAL -e vim ~/.config/mako/config;;
    "$e")
        $TERMINAL -e vim ~/.config/sway/config;;
    "$f")
        $TERMINAL -e vim ~/.dotfiles/other/stuff2remember.txt;;
    "$g")
        $TERMINAL -e vim ~/.dotfiles/nixos/hosts/zbook/configuration.nix;;
    "$h")
        $TERMINAL -e vim ~/.dotfiles/nixos/flake.nix;;
    "$i")
        $TERMINAL -e vim ~/.dotfiles/nixos/modules/pkgs.nix;;
    "$j")
        $TERMINAL --class update -e sudo nix flake update --flake ~/.dotfiles/nixos/ && notify-send -c center -i dialog-information "Update kompletní"
esac
