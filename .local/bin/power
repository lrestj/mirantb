#!/bin/bash

a="Zamknout"
b="Odhlásit"
c="Uspat"
d="Restart"
e="Vypnout"
ai="\0icon\x1fsystem-lock-screen"
bi="\0icon\x1fsystem-log-out"
ci="\0icon\x1fsystem-suspend"
di="\0icon\x1fsystem-reboot"
ei="\0icon\x1fsystem-shutdown"

selected=$(echo -e "$a$ai\n$b$bi\n$c$ci\n$d$di\n$e$ei" | fuzzel --config ~/.config/fuzzel/power.ini -d )
case $selected in
    "$a")
        swaylock -f -F -e -k -c 000000;;
    "$b")
        sleep 1; swaymsg exit;;
    "$c")
        sleep 1; systemctl suspend;;
    "$d")
        sleep 1; systemctl reboot;;
    "$e")
        sleep 1; systemctl shutdown;;
esac
