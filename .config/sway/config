##### SWAY CONFIG #####

### Monitor settings
    # output * adaptive_sync on
    output * bg /run/current-system/sw/share/backgrounds/sway/Sway_Wallpaper_Blue_1920x1080.png fill

### Input configuration
    input type:touchpad {
        dwt enabled
        tap enabled
        natural_scroll disabled
        middle_emulation enabled
        pointer_accel 0.4
    }
    input type:keyboard {
        xkb_layout "cz"
        xkb_options caps:swapescape
        xkb_numlock enabled
    }

    # Focus
    for_window [urgent="latest"] focus
    focus_follows_mouse no

### Variables
    set $mod Mod4
    set $cs Ctrl+Shift
    set $ca Ctrl+Alt
    set $ma Mod4+Alt
    set $ms Mod4+Shift
    set $term foot
    set $editor $term -e vim
    set $browser brave
    set $menu rofi -show drun -show-icons -sidebar-mode
    set $filemgr thunar

### Apps at startup
    exec_always waypaper --restore &
    exec nm-applet --indicator &
    exec lxqt-policykit-agent &
    exec wl-paste --watch cliphist store
    exec wlsunset -l 50.1 -L 16.2 -t 4700 -T 5000 # Screen blue light settings
    exec udiskie -t
    exec swayosd-server
    exec_always ~/.dotfiles/scripts/battery-check.sh

### Locking the system
    set $lock swaylock -f -F -e -k -c 000000
    set $logout sleep 1 && swaymsg exit
    bindsym --to-code $ca+Delete exec $lock
    bindsym --to-code $mod+Delete exec $logout
    
### Idle configuration
    exec_always killall swayidle; swayidle -w \
       timeout 150 'brightnessctl -s set 400' resume 'brightnessctl -r' \
       # timeout 300 'swaylock -f -F -e -k -c 000000' \
       timeout 580 'notify-send -i video-display "Displej se za okamžik vypne"' \
       timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
       before-sleep 'swaylock -f -F -e -k -c 000000'
    
### Cursor theme
    seat seat0 xcursor_theme Banana 28
    # seat seat0 xcursor_theme Bibata-Modern-Classic 24

### Status Bar:
    bar {
        swaybar_command waybar-sway
        position top
    }

### No window bars
    default_border pixel 4
    default_floating_border pixel 5
    client.focused #8000FF #8000FF #8000FF

### Keybindings
    bindsym $mod+a exec $term
    bindsym $cs+y exec $term -e yazi
    bindsym $cs+e exec $term -T Vim -a Vim -e vim
    bindsym $cs+b exec brave
    bindsym $cs+f exec thunar
    bindsym $cs+s exec simple-scan
    bindsym $cs+k exec pkill $kalk || $kalk
    bindsym $cs+w exec waypaper
    bindsym $cs+m exec  ~/.dotfiles/scripts/clouds.sh   

    # Mako emergency
    bindsym $ca+m exec makoctl dismiss --all && makoctl reload

    # Start launcher
    bindsym --release SUPER_L exec pkill rofi || $menu

    # Touchpad ON/OFF
    bindsym $ca+t exec $term --app-id script -e ~/.dotfiles/scripts/asktouchpad.sh

    # Nápověda
    bindsym $mod+n exec ~/.dotfiles/scripts/helpnotify.sh
    bindsym Alt+n exec ~/.dotfiles/scripts/binds.sh

    # Time & date
    bindsym $mod+d exec ~/.dotfiles/scripts/datetimenotify.sh

    # Toggle waybar
    bindsym $mod+Return exec pkill waybar || waybar-sway
    bindsym $ma+Return exec pkill waybar && waybar --config ~/.config/waybar/config-taskbar

    # Clipboard toggle
    bindsym $mod+c exec pkill rofi || cliphist list | rofi -dmenu -display-columns 2 | cliphist decode | wl-copy

    # Opacity
    bindsym $mod+p opacity plus 0.05
    bindsym $mod+o opacity minus 0.05

    # Menu wlogout
    bindsym $mod+y exec pkill wlogout || wlogout -s -c 5 -r 5 -L 360 -R 360
    bindsym $mod+x exec pkill wlogout || ~/.dotfiles/scripts/power.sh

    # Reload the configuration file
    bindsym $ms+c reload

    # Kill focused window
    bindsym $mod+q kill

    # Move your focus around
    bindsym $mod+h focus left
    bindsym $mod+j focus down
    bindsym $mod+k focus up
    bindsym $mod+l focus right
    bindsym $mod+Left focus left
    bindsym $mod+Down focus down
    bindsym $mod+Up focus up
    bindsym $mod+Right focus right

    # Move the focused window 
    bindsym $ma+h move left
    bindsym $ma+j move down
    bindsym $ma+k move up
    bindsym $ma+l move right

    # Resize container
    bindsym $ms+Left resize shrink width 10px
    bindsym $ms+Down resize grow height 10px
    bindsym $ms+Up resize shrink height 10px
    bindsym $ms+Right resize grow width 10px

    # Switch to workspace
    bindsym Alt+left workspace number 1
    bindsym Alt+right workspace number 2
    bindsym Alt+down workspace number 3
    bindsym Alt+up workspace number 4

    # Move focused container to workspace
    bindsym $ma+Left move container to workspace number 1
    bindsym $ma+Right move container to workspace number 2
    bindsym $ma+Down move container to workspace number 3
    bindsym $ma+Up move container to workspace number 4

    # Cycle workspaces
    bindsym Ctrl+Tab workspace next

    # Layout toggle
    bindsym $mod+w layout toggle split
    bindsym $mod+f layout toggle tabbed splith

    # Make the current focus fullscreen
    bindsym $ma+f fullscreen

    # Toggle the current focus between tiling and floating mode
    bindsym $ca+f floating toggle

    # Swap focus between the tiling area and the floating area
    bindsym $mod+space focus mode_toggle

    # Move window to the scratchpad and show
    bindsym $ma+s move scratchpad
    bindsym $mod+s scratchpad show

    # Screenshot with grimshot
    bindsym $mod+Insert exec grimshot --notify save anything

### Media keys for SwayOSD
    # Audio and mic mute
    bindsym XF86AudioMute exec swayosd-client --output-volume mute-toggle
    bindsym XF86AudioMicMute exec swayosd-client --input-volume mute-toggle
    
    # Volume
    bindsym XF86AudioRaiseVolume exec swayosd-client --output-volume raise --max-volume 120
    bindsym XF86AudioLowerVolume exec swayosd-client --output-volume lower --max-volume 120
    
    # Capslock but specific LED name (/sys/class/leds/)
    bindsym --release Caps_Lock exec swayosd-client --caps-lock-led input2::capslock
    
    # Brightness
    bindsym XF86MonBrightnessUp  exec swayosd-client --brightness +10
    bindsym XF86MonBrightnessDown exec swayosd-client --brightness -10    # # Special keys to adjust volume via PulseAudio

### MODES:
    # Nastavení
    bindsym $cs+n mode "Nastavení"; exec ~/.dotfiles/scripts/nsubmap.sh
    mode "Nastavení" {
    bindsym v exec makoctl dismiss && $editor ~/.config/vim/vimrc; mode "default"
    bindsym y exec makoctl dismiss && $editor ~/.config/yazi/keymap.toml; mode "default"
    bindsym w exec makoctl dismiss && $editor ~/.config/waybar/config-sway.jsonc; mode "default"
    bindsym m exec makoctl dismiss && $editor ~/.config/mako/config; mode "default"
    bindsym c exec makoctl dismiss && $editor ~/.dotfiles/nixos/hosts/zbook/configu; mode "default"ration.nix
    bindsym f exec makoctl dismiss && $editor ~/.dotfiles/nixos/flake.nix; mode "default"
    bindsym p exec makoctl dismiss && $editor ~/.dotfiles/nixos/modules/pkgs.nix; mode "default"
    bindsym a exec makoctl dismiss && $editor ~/.config/hypr/1-envAutostartDefaultApps.conf; mode "default"
    bindsym i exec makoctl dismiss && $editor ~/.config/hypr/2-inputLookFeel.conf; mode "default"
    bindsym b exec makoctl dismiss && $editor ~/.config/hypr/3-keyBindings.conf; mode "default"
    bindsym r exec makoctl dismiss && $editor ~/.config/hypr/4-windowsRules.conf; mode "default"
    bindsym s exec makoctl dismiss && $editor ~/.config/sway/config; mode "default"
    bindsym h exec makoctl dismiss && hyprctl reload; mode "default"
    bindsym x exec makoctl dismiss && makoctl reload; mode "default"
    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
    }
    # Wenmarks
    bindsym $cs+i mode "Webmarks"; exec ~/.dotfiles/scripts/webmarks.sh
    mode "Webmarks" {
    bindsym g exec makoctl dismiss && $browser https://mail.google.com/mail/u/0/; mode "default"
    bindsym n exec makoctl dismiss && $browser https://search.nixos.org/packages; mode "default"
    bindsym p exec makoctl dismiss && $browser https://prehrajto.cz/; mode "default"
    bindsym s exec makoctl dismiss && $browser https://sdilej.cz/; mode "default"
    bindsym t exec makoctl dismiss && $browser http://titulky.cz/; mode "default"
    bindsym f exec makoctl dismiss && $browser https://www.nerdfonts.com/cheat-sheet; mode "default"
    # Return to default mode
    bindsym Return mode "default"
    bindsym Escape mode "default"
    }

### Windows rules
    for_window [class=".*"] move left
    for_window [app_id="org.gnome.Calculator"] floating enable, move right 480, move up 55
    for_window [app_id="org.pulseaudio.pavucontrol"] floating enable, resize set 630 400, move position 700px 3px
    for_window [app_id="script"] floating enable, resize set 400 100


include /etc/sway/config.d/*

