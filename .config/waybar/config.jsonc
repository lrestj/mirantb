// -*- mode: jsonc -*-

// WAYBAR AT THE TOP

[{
    // "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 38, // Waybar height (to be removed for auto height)
    "autohide": true,
    "autohide-blocked": false,
    "margin-top": 1,
    "margin-left": 8,
    "margin-right": 8,
    // "width": 1280, // Waybar width
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap",
        "memory",
        "cpu",
        "temperature",
        "custom/scan",
        "custom/office",
        "custom/kalk",
        "custom/text",
        "custom/fm",
        "custom/browser",
        "custom/media"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "idle_inhibitor",
        "mpd",
        "pulseaudio",
        "backlight",
        "tray",
        "clock",
        "battery",
        "power-profiles-daemon",
        "hyprland/language",
        "custom/power"
    ],
    "hyprland/workspaces": {
        "format": "{icon}",
        "show-special": true,
        "cursor": true
    },
    "hyprland/submap": {
        "format": "✌️ {}",
        "max-length": 12,
        "tooltip": false
    },
    "custom/menu": {
        "format": "   Menu  ",
        "tooltip-format": "Aplikace",
        "on-click": "pkill rofi || rofi -show drun -show-icons",
        "on-click-right": "wlogout"
    },

    "memory": {
        "format": "  Menu   {}% ",
        "on-click": "pkill rofi || rofi -show drun -show-icons",
        "on-click-right": "wlogout -b 2 -T 10 -L 10 -R 980 -B 525 -s -c 5 -r 5 -l ~/.config/wlogout/menu"
    },

    "cpu": {
        "format": "  {usage}%",
        "tooltip": false,
        "on-click": "foot",
        "on-click-right": "",
        "on-click-middle": ""
    },

    "temperature": {
        "thermal-zone": 0,
        "critical-threshold": 80,
        "format": " {icon} {temperatureC} °C  ",
        "format-icons": ["", "", ""],
        "on-click": "pkill btop || foot -T btop -e btop",
        "on-click-right": ""
    },

   "custom/scan": {
        "format":"       ",
        "tooltip-format": "Skener",
        "on-click": "pkill simple-scan || simple-scan"
    },

    "custom/office": {
        "format":"       ",
        "tooltip-format": "LibreOffice",
        "on-click": "libreoffice",
        "on-click-right": "libreoffice --writer"
    },

    "custom/kalk": {
        "format":"       ",
        "tooltip-format": "Kalkulačka",
        "on-click": "pkill $kalk || $kalk"
    },

    "custom/text": {
        "format":"     ",
        "tooltip-format": "Textový editor",
        "on-click": "pkill geany || geany"
    },

   "custom/fm": {
        "format":"        ",
        "tooltip-format": "Soubory",
        "on-click": "pkill thunar || thunar"
    },

   "custom/browser": {
        "format":"      ",
        "tooltip-format": "Internet",
        "on-click": "brave"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "",
            "deactivated": ""
        },
        "on-click-right": "waybar --config ~/.config/waybar/config-taskbar"
    },

    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon}   {format_source}",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": " {format_source}",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pkill pavucontrol || pavucontrol"
    },

    "backlight": {
        // "device": "acpi_video1",
        "format": "  {percent}% {icon} ",
        "format-icons": ["", "", "", "", "", "", "", "", ""],
        "on-click-right": "pkill foot || foot",
        "on-click": "pkill btop || foot -T btop -e btop"
    },

    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },

    "clock": {
        "timezone": "Europe/Prague",
        "locale": "cs_CZ.UTF-8",
        "format": "{:%H:%M 🕘}",
        "tooltip-format": "<big>{:L%e L%B %Y }</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:L%A %d.%m.%Y}"
    },

    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ",
        "format-plugged": "{capacity}% ",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["", "", "", "", ""]
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "  ",
            "performance": "  ",
            "balanced": " ",
            "power-saver": " "
        }
    },
    "hyprland/language": {
        "format": " {} ",
        "min-length" : 4,
        "format-cs": "🇨🇿",
        "format-en": "🇺🇸",
        "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next"
    },

    "custom/power": {
        "format" : "  ",
        "tooltip-format": "Vypnout...",
        "menu": "on-click",
        "menu-file": "~/.config/waybar/power_menu.xml",
        "menu-actions": {
            "uspat": "systemctl suspend",
            "odhlásit": "sleep 1 && hyprctl dispatch exit",
            "vypnout": "systemctl poweroff",
            "restart": "systemctl reboot"
        }
    }
}, 


// TASK BAR AT THE RIGHT

{
    "layer": "top", // Waybar at top layer
    "position": "right", 
    //"height": 30,
    // "width": 1280,
    "spacing": 4,
    // Choose the order of the modules
    "modules-center": ["wlr/taskbar"],
    // Modules configuration
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 30,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "close"
    }
}]

// END OF FILE
